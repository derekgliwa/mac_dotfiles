#!/usr/bin/env zsh
# Managed by chezmoi. Personal customizations go in ~/.zshrc.d/*.zsh (unmanaged).

[[ -f /etc/zshrc ]] && . /etc/zshrc

# Load brew into PATH early (mise activation below needs it).
[[ -x /opt/homebrew/bin/brew ]] && eval "$(/opt/homebrew/bin/brew shellenv)"
[[ -x /home/linuxbrew/.linuxbrew/bin/brew ]] && eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"

# Ensure ~/.local/bin is on PATH (user scripts like oc-local live there).
case ":$PATH:" in
  *":$HOME/.local/bin:"*) ;;
  *) PATH="$HOME/.local/bin:$PATH" ;;
esac

# Numbered modules control load order. (N) prevents errors if empty.
for rc in "$HOME"/.zshrc.d/*.zsh(N); do
  . "$rc"
done
unset rc
